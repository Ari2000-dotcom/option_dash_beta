# Upstox OAuth credentials
# Get these from https://upstox.com/developer/apps
UPSTOX_API_KEY=
UPSTOX_API_SECRET=
UPSTOX_REDIRECT_URI=

# Your Upstox login credentials
UPSTOX_PHONE=
UPSTOX_PIN=

# TOTP secret — in Upstox app: Profile → Security → TOTP → "Show Secret Key"
# Looks like: JBSWY3DPEHPK3PXP
UPSTOX_TOTP_SECRET=
